<script setup>
import { gsap } from 'gsap';
import introSound from "~/assets/sounds/intro.mp3"
// import { getRandomBetween } from '~/utils/randoms';

const showButton = ref(true);

const handleClick = () => {
  showButton.value = false;
  startAnimation.value = true;
  const sound = new Audio(introSound);
  sound.play();
}

const startAnimation = ref(false);
const showLoader = ref(true);
const showContainer = ref(true);
const secondsLoader = 8;
const secondsContainer = secondsLoader + 2;

onMounted(() => {

  // const playedSound = false;
  // function playSound() {
  //   if (!playedSound) {
  //     const sound = new Audio(introSound);
  //     sound.play();
  //     playedSound = true;
  //   }
  // }
  // document.body.addEventListener('mouseover', playSound, { once: true });
  // document.body.addEventListener('click', playSound, { once: true });
  // document.body.addEventListener('mouseout', playSound, { once: true });

  gsap.config({ trialWarn: false });
  let select = s => document.querySelector(s),
    toArray = s => gsap.utils.toArray(s),
    mainSVG = select('#mainSVG'),
    allEll = toArray('.ell'),
    colorArr = ['#359EEE', '#FFC43D', '#EF476F', '#03CEA4']

  let colorInterp = gsap.utils.interpolate(colorArr);

  gsap.set(mainSVG, {
    visibility: 'visible'
  })

  function animate(el, count) {
    let tl = gsap.timeline({
      defaults: {
        ease: 'sine.inOut'
      },
      repeat: -1
    });
    gsap.set(el, {
      opacity: 1 - count / (allEll.length),
      stroke: colorInterp(count / (allEll.length))
    })

    tl.to(el, {
      attr: {
        ry: `+=${count * 2}`,
        rx: `+=${count * 2}`
      },
      ease: 'sine.in'
    })
      .to(el, {
        attr: {
          ry: `+=${count * 2}`,
          rx: `+=${count * 2}`
        },
        ease: 'sine'
      })
      .to(el, {
        duration: secondsLoader,
        rotation: 2160,
        transformOrigin: '50% 50%'
      }, 0).timeScale(0.6);
  }

  watchEffect(() => {
    if (startAnimation.value) {
      allEll.forEach((c, i) => {
        gsap.delayedCall(i / (allEll.length - 1), animate, [c, i + 1])
      });

      gsap.to('#aiGrad', {
        duration: 4,
        delay: 0.25,
        attr: {
          x1: '+=380',
          x2: '+=300'
        },
        scale: 1.4,
        transformOrigin: '50% 50%',
        repeat: 1,
        ease: 'none'
      })

      gsap.to('#ai', {
        duration: 8,
        scale: 3,
        transformOrigin: '50% 50%',
        repeat: 1,
        yoyo: true,
        ease: 'sine.inOut'
      })

      gsap.to(allEll, {
        duration: secondsLoader - 2,
        opacity: 0,
        ease: "sine.inOut",
      });

      gsap.to("#version", {
        duration: secondsLoader - 2,
        opacity: 0,
        ease: "sine.inOut",
      });

      setTimeout(() => {
        showLoader.value = false;
        document.body.removeEventListener('mouseover', playSound, { once: true });
        document.body.removeEventListener('click', playSound, { once: true });
        document.body.removeEventListener('mouseout', playSound, { once: true });
      }, secondsLoader * 1000);

      setTimeout(() => {
        showContainer.value = false;
      }, secondsContainer * 1000);
    }
  });
});

</script>

<style scoped>
.start-button {
  z-index: 9999 !important;
}

.loader-container {
  position: fixed;
  top: 0;
  left: 0;
  z-index: 9999;
  background: radial-gradient(circle at center, #17011a, #05000F, #010411);
  overflow: hidden;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
  width: 100vw;
  margin: 0;
  padding: 0;
  transition: opacity 3s ease;
}

svg {
  width: 100%;
  height: 100%;
  visibility: hidden;
  opacity: 50%;
}

.ell,
#ai {
  fill: none;
}
</style>
