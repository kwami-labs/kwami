{
  "name": "kwami",
  "version": "1.5.12",
  "description": "A 3D Interactive AI Companion Library - Create engaging AI companions with visual (blob), audio, and AI capabilities",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "keywords": [
    "3d",
    "threejs",
    "ai",
    "companion",
    "audio",
    "visualization",
    "blob",
    "interactive",
    "webgl",
    "typescript"
  ],
  "author": "Alex Colls",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexcolls/kwami",
    "directory": "kwami"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:coverage:ui": "vitest --coverage --ui",
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build && npm test",
    "postpublish": "echo '✅ Successfully published kwami to npm!'"
  },
  "dependencies": {
    "@distube/ytdl-core": "^4.14.4",
    "@elevenlabs/elevenlabs-js": "^2.20.1",
    "@solana/web3.js": "^1.95.8",
    "js-yaml": "^4.1.1",
    "simplex-noise": "^4.0.1",
    "three": ">=0.150.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.1",
    "@types/three": "^0.160.0",
    "@vitest/coverage-v8": "^4.0.9",
    "@vitest/ui": "^4.0.9",
    "happy-dom": "^20.0.10",
    "typescript": "^5.3.0",
    "vite": "^7.2.7",
    "vitest": "^4.0.13"
  },
  "peerDependencies": {
    "three": ">=0.150.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/src/core/Kwami.js",
      "types": "./dist/src/core/Kwami.d.ts"
    },
    "./blob": {
      "import": "./dist/src/core/body/blob/Blob.js",
      "types": "./dist/src/core/body/blob/Blob.d.ts"
    },
    "./ui": {
      "import": "./dist/src/ui/index.js",
      "types": "./dist/src/ui/index.d.ts"
    },
    "./ui/rings": {
      "import": "./dist/src/ui/rings/index.js",
      "types": "./dist/src/ui/rings/index.d.ts"
    },
    "./ui/welcome": {
      "import": "./dist/src/ui/welcome/index.js",
      "types": "./dist/src/ui/welcome/index.d.ts"
    },
    "./utils": {
      "import": "./dist/src/utils/randoms.js",
      "types": "./dist/src/utils/randoms.d.ts"
    },
    "./types": {
      "types": "./dist/src/types/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0",
    "deno": ">=1.0.0"
  },
  "packageManager": "npm@10.8.2"
}
