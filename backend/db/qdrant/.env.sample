# Qdrant Configuration
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_LOG_LEVEL=INFO

# API Key (optional for dev, required for production)
QDRANT_API_KEY=

# Connection URLs (for application use)
QDRANT_URL=http://localhost:${QDRANT_HTTP_PORT}
QDRANT_GRPC_URL=http://localhost:${QDRANT_GRPC_PORT}
