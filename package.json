{
  "name": "kwami",
  "version": "1.3.1",
  "description": "A 3D Interactive AI Companion Library - Create engaging AI companions with visual (blob), audio, and AI capabilities",
  "type": "module",
  "main": "index.ts",
  "types": "src/types/index.ts",
  "keywords": [
    "3d",
    "threejs",
    "ai",
    "companion",
    "audio",
    "visualization",
    "blob",
    "interactive",
    "webgl",
    "typescript"
  ],
  "author": "Alex Colls",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexcolls/kwami"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "sync-version": "node scripts/sync-version.js",
    "prebuild": "npm run sync-version",
    "build": "tsc",
    "dev": "tsc --watch",
    "playground": "vite playground --port 3000",
    "pg": "npm run playground",
    "build:playground": "vite build playground"
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.20.1",
    "js-yaml": "^4.1.1",
    "simplex-noise": "^4.0.1",
    "three": ">=0.150.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/three": "^0.160.0",
    "typescript": "^5.3.0",
    "vite": "^7.1.12"
  },
  "peerDependencies": {
    "three": ">=0.150.0"
  },
  "exports": {
    ".": {
      "import": "./index.ts",
      "types": "./src/types/index.ts"
    },
    "./core": {
      "import": "./src/core/Kwami.ts",
      "types": "./src/types/index.ts"
    },
    "./blob": {
      "import": "./src/blob/Blob.ts"
    },
    "./utils": {
      "import": "./src/utils/randoms.ts"
    },
    "./types": {
      "types": "./src/types/index.ts"
    }
  },
  "files": [
    "src",
    "index.ts",
    "README.md",
    "CHANGELOG.md",
    "!src/assets"
  ]
}
