{
  "name": "kwami",
  "version": "1.5.8",
  "description": "KWAMI Ecosystem - Monorepo containing the core library and all related projects",
  "license": "SEE LICENSE IN LICENSE.md",
  "private": true,
  "type": "module",
  "workspaces": [
    "kwami",
    "pg",
    "app",
    "web"
  ],
  "scripts": {
    "test": "npm run test -w kwami",
    "test:watch": "npm run test:watch -w kwami",
    "test:ui": "npm run test:ui -w kwami",
    "test:coverage": "npm run test:coverage -w kwami",
    "build": "npm run build -w kwami",
    "dev": "npm run dev -w kwami",
    "web": "npm run dev -w web -- --port 3333",
    "build:web": "npm run build -w web",
    "preview:web": "npm run preview -w web",
    "playground": "npm run dev -w pg -- --port 4444",
    "build:playground": "npm run build -w pg",
    "preview:playground": "npm run preview -w pg",
    "pg": "npm run playground",
    "build:pg": "npm run build:playground",
    "preview:pg": "npm run preview:playground",
    "app": "npm run dev -w app -- --port 5555",
    "build:app": "npm run build -w app",
    "preview:app": "npm run preview -w app",
    "candy": "npm run dev -w candy -- --port 6666",
    "build:candy": "npm run build -w candy",
    "preview:candy": "npm run preview -w candy",
    "dao": "npm run dev -w dao -- --port 7777",
    "build:dao": "npm run build -w dao",
    "preview:dao": "npm run preview -w dao",
    "market": "npm run dev -w market -- --port 8888",
    "build:market": "npm run build -w market",
    "preview:market": "npm run preview -w market",
    "publish:kwami": "npm publish -w kwami",
    "version:kwami": "npm view kwami",
    "sync-version": "node scripts/sync-version.js"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.3.0",
    "vite": "^7.1.12"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0",
    "deno": ">=1.0.0"
  },
  "packageManager": "npm@10.8.2"
}