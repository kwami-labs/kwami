{
  "name": "kwami-playground",
  "private": true,
  "version": "2.0.0",
  "description": "Kwami Playground - Professional development and testing environment",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .js,.ts",
    "lint:fix": "eslint src --ext .js,.ts --fix",
    "format": "prettier --write \"src/**/*.{js,ts,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,json,css}\""
  },
  "dependencies": {
    "kwami": "*"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@types/node": "^22.8.7",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "@vitest/coverage-v8": "^2.1.4",
    "@vitest/ui": "^2.1.4",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "happy-dom": "^15.7.4",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vite": "^7.2.2",
    "vitest": "^2.1.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "kwami",
    "playground",
    "3d",
    "webgl",
    "ai",
    "blob",
    "audio-reactive",
    "typescript"
  ],
  "author": "KWAMI Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexcolls/kwami.git",
    "directory": "pg"
  },
  "bugs": {
    "url": "https://github.com/alexcolls/kwami/issues"
  },
  "homepage": "https://github.com/alexcolls/kwami/tree/main/pg#readme"
}
