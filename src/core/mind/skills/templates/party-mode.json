{
  "id": "party-mode",
  "name": "Party Mode",
  "description": "Celebration mode with rapid color changes and energetic movement",
  "version": "1.0.0",
  "author": "Kwami Team",
  "tags": ["celebration", "animation", "fun"],
  "trigger": "manual",
  "loop": false,
  "actions": [
    {
      "type": "sequence",
      "parallel": true,
      "actions": [
        {
          "type": "body.scale",
          "preset": "large",
          "duration": 500,
          "easing": "bounce"
        },
        {
          "type": "body.spikes",
          "x": 1.5,
          "y": 1.5,
          "z": 1.5
        },
        {
          "type": "body.time",
          "x": 5.0,
          "y": 5.0,
          "z": 5.0
        },
        {
          "type": "body.rotation",
          "x": 0.005,
          "y": 0.008,
          "z": 0.003
        }
      ]
    },
    {
      "type": "sequence",
      "actions": [
        {
          "type": "body.colors",
          "primary": "#ff006e",
          "secondary": "#8338ec",
          "accent": "#ffbe0b",
          "duration": 300
        },
        {
          "type": "body.colors",
          "primary": "#3a86ff",
          "secondary": "#ff006e",
          "accent": "#06ffa5",
          "duration": 300
        },
        {
          "type": "body.colors",
          "primary": "#ffbe0b",
          "secondary": "#fb5607",
          "accent": "#ff006e",
          "duration": 300
        },
        {
          "type": "body.colors",
          "primary": "#06ffa5",
          "secondary": "#3a86ff",
          "accent": "#8338ec",
          "duration": 300
        }
      ]
    }
  ]
}

